# === Server ===
PORT=3000
NODE_ENV=development

# === API Keys ===
NEXT_PUBLIC_RPC_URL=https://base-sepolia.publicnode.com
NEXT_PUBLIC_API_URL=https://demo.castquest.app/api
NEXT_PUBLIC_ENV=demo

# === Database ===
DATABASE_URL=postgresql://user:password@localhost:5432/askapp

# === Authentication ===
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# === OAuth (optional, disabled by default) ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Logging ===
LOG_LEVEL=info

# === Rate Limiting ===
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

